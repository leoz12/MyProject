{
  "expo": {
    "name": "myProduct",
    "slug": "myProduct",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "myproduct",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myproduct"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF"
      },
      "package": "com.myproduct"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF",
          "image": "./assets/splash-icon.png"
        }
      ],
      "@react-native-vector-icons/ant-design"
    ]
  }
}
